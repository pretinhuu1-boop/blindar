{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/pretinhuu1-boop/blindar/blob/main/schemas/findings.schema.json",
  "title": "blindar adversarial findings",
  "description": "Output de uma lente do adversarial review (Fase 4). Cada finding passa pelo verify.",
  "type": "object",
  "required": ["findings"],
  "properties": {
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "lens", "sev", "description"],
        "properties": {
          "title": {
            "type": "string",
            "description": "Resumo de 1 linha"
          },
          "lens": {
            "enum": ["security", "races", "failmodes", "regression"],
            "description": "Lente que produziu este finding"
          },
          "sev": { "enum": ["crit", "high", "med", "low"] },
          "file": { "type": "string", "description": "Arquivo onde o problema vive" },
          "line": { "type": "number" },
          "description": {
            "type": "string",
            "description": "Por que isso é um problema, evidência"
          },
          "repro": {
            "type": "string",
            "description": "Como reproduzir o problema (steps ou snippet)"
          },
          "suggested_fix_category": {
            "type": "string",
            "description": "Qual agente deveria pegar isso (security, resilience, etc.)"
          }
        }
      }
    }
  }
}
